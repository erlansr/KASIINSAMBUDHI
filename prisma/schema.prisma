generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Keluarga {
  id           Int          @id @default(autoincrement())
  namaKeluarga String
  alamat       String?
  noTelepon    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  pembayaran   Pembayaran[]
}

model Pembayaran {
  id              Int       @id @default(autoincrement())
  keluargaId      Int
  bulan           String
  nominal         Int
  status          String    @default("belum_lunas")
  midtransOrderId String?
  paidAt          DateTime?
  paymentMethod   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  transactionId   String?
  keluarga        Keluarga  @relation(fields: [keluargaId], references: [id])

  @@index([keluargaId], map: "Pembayaran_keluargaId_fkey")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
